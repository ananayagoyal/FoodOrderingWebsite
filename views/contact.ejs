<%- include("partials/header") %>

<section class="contact-section">

    <div class="contact-container">

        <div class="contact-left">
            <h1>Contact Us</h1>
            <p>
                Facing any issue with your order?  
                Have complaints or suggestions?  
                We would love to hear from you.
            </p>

            <div class="contact-info">
                <p>📞 Phone: +91 1234567890</p>
                <p>📧 Email: foodiehub@gmail.com</p>
                <p>📍 Address: Punjab, India</p>
            </div>
        </div>

        <div class="contact-right">
            <form action="/contact" method="POST">

                <input type="text" name="name" placeholder="Your Name" required>

                <input type="email" name="email" placeholder="Your Email" required>

                <textarea name="message" rows="5" placeholder="Write your complaint or message..." required></textarea>

                <button type="submit" class="btn-primary">Send Message</button>

            </form>
        </div>

    </div>

</section>

<%- include("partials/footer") %>