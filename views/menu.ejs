<%- include("partials/header") %>

<section class="menu-section">

    <h1 class="menu-title">Our Delicious Menu</h1>
    <p class="menu-subtitle">Freshly prepared food delivered to your doorstep</p>

    <div class="menu-container">

        <!-- Paneer Butter Masala -->
        <div class="food-card">
            <img src="/images/paneer.jpg">
            <h3>Paneer Butter Masala</h3>
            <p>Soft paneer cubes cooked in buttery tomato gravy.</p>
            <span class="price">₹240</span>
            <button class="btn-primary">Add to Cart</button>
        </div>

        <!-- Biryani -->
        <div class="food-card">
            <img src="/images/biryani.jpg">
            <h3>Veg Biryani</h3>
            <p>Authentic aromatic basmati rice with fresh veggies.</p>
            <span class="price">₹220</span>
            <button class="btn-primary">Add to Cart</button>
        </div>

        <!-- Masala Dosa -->
        <div class="food-card">
            <img src="/images/dosa.jpg">
            <h3>Masala Dosa</h3>
            <p>Crispy dosa filled with spicy potato masala.</p>
            <span class="price">₹120</span>
            <button class="btn-primary">Add to Cart</button>
        </div>

        <!-- Burger -->
        <div class="food-card">
            <img src="/images/burger.jpg">
            <h3>Cheese Burger</h3>
            <p>Juicy grilled patty with cheese and fresh veggies.</p>
            <span class="price">₹150</span>
            <button class="btn-primary">Add to Cart</button>
        </div>

        <!-- Pizza -->
        <div class="food-card">
            <img src="/images/pizza.jpg">
            <h3>Veggie Pizza</h3>
            <p>Loaded with capsicum, onion, olives and cheese.</p>
            <span class="price">₹260</span>
            <button class="btn-primary">Add to Cart</button>
        </div>

        <!-- Chole Bhature -->
        <div class="food-card">
            <img src="/images/chole.jpg">
            <h3>Chole Bhature</h3>
            <p>Classic North Indian spicy chickpea curry with bhature.</p>
            <span class="price">₹140</span>
            <button class="btn-primary">Add to Cart</button>
        </div>

        <!-- Momos -->
        <div class="food-card">
            <img src="/images/momos.jpg">
            <h3>Veg Momos</h3>
            <p>Steamed dumplings served with spicy chutney.</p>
            <span class="price">₹110</span>
            <button class="btn-primary">Add to Cart</button>
        </div>

    </div>

</section>

